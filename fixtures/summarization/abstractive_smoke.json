{
	"id": "summarization_abstractive_smoke",
	"category": "summarization",
	"description": "LLM-driven abstractive summary. Skipped automatically when KREUZBERG_LLM_API_KEY (or OPENAI_API_KEY) is not set.",
	"tags": ["summarization", "abstractive", "llm"],
	"call": "extract_file_sync",
	"input": {
		"path": "text/book_war_and_peace_1p.txt",
		"config": {
			"summarization": {
				"strategy": "abstractive",
				"max_tokens": 150,
				"llm": {
					"model": "openai/gpt-4o-mini",
					"temperature": 0.0,
					"max_tokens": 200
				}
			}
		}
	},
	"assertions": [
		{ "type": "not_error" },
		{
			"type": "not_empty",
			"field": "summary.text"
		},
		{
			"type": "equals",
			"field": "summary.strategy",
			"value": "abstractive"
		}
	],
	"skip": {
		"languages": [
			"python",
			"rust",
			"node",
			"go",
			"ruby",
			"elixir",
			"wasm",
			"java",
			"csharp",
			"php",
			"r",
			"dart",
			"kotlin_android",
			"swift",
			"zig"
		],
		"reason": "Requires liter-llm feature and KREUZBERG_LLM_API_KEY env var; runtime-only skip; deterministic extractive variant covers offline CI"
	}
}
