    # EPUB metadata (Dublin Core extensions).

    attr_accessor coverage: String?
    attr_accessor dc_format: String?
    attr_accessor relation: String?
    attr_accessor source: String?
    attr_accessor dc_type: String?
    attr_accessor cover_image: String?

    def initialize: (?coverage: String, ?dc_format: String, ?relation: String, ?source: String, ?dc_type: String, ?cover_image: String) -> void
  end

