    # Outlook PST archive metadata.

    attr_accessor message_count: Integer?

    def initialize: (message_count: Integer) -> void
  end

  class OcrConfidence
    # Confidence scores for an OCR element.
    #
    # Separates detection confidence (how confident that text exists at this location)
    # from recognition confidence (how confident about the actual text content).

    # Detection confidence: how confident the OCR engine is that text exists here.
    #
    # PaddleOCR provides this as `box_score`, Tesseract doesn't have a direct equivalent.
    # Range: 0.0 to 1.0 (or None if not available).
    attr_accessor detection: Float?
    # Recognition confidence: how confident about the text content.
    #
    # Range: 0.0 to 1.0.
    attr_accessor recognition: Float?

    def initialize: (?detection: Float, recognition: Float) -> void
  end

  class OcrRotation
    # Rotation information for an OCR element.

    # Rotation angle in degrees (0, 90, 180, 270 for PaddleOCR).
    attr_reader angle_degrees: Float
    # Confidence score for the rotation detection.
    attr_reader confidence: Float

    def initialize: (angle_degrees: Float, ?confidence: Float) -> void
  end

  class OcrElement
    # A unified OCR element representing detected text with full metadata.
    #
    # This is the primary type for structured OCR output, preserving all information
    # from both Tesseract and PaddleOCR backends.

    # The recognized text content.
    attr_accessor text: String?
    # Bounding geometry (rectangle or quadrilateral).
    attr_accessor geometry: OcrBoundingGeometry?
    # Confidence scores for detection and recognition.
    attr_accessor confidence: OcrConfidence?
    # Hierarchical level (word, line, block, page).
    attr_accessor level: OcrElementLevel?
    # Rotation information (if detected).
    attr_accessor rotation: OcrRotation?
    # Page number (1-indexed).
    attr_accessor page_number: Integer?
    # Parent element ID for hierarchical relationships.
    #
    # Only used for Tesseract output which has word -> line -> block hierarchy.
    attr_accessor parent_id: String?
    # Backend-specific metadata that doesn't fit the unified schema.
    attr_accessor backend_metadata: Hash[String, untyped]?

    def initialize: (text: String, geometry: OcrBoundingGeometry, confidence: OcrConfidence, level: OcrElementLevel, ?rotation: OcrRotation, page_number: Integer, ?parent_id: String, backend_metadata: Hash[String, untyped]) -> void
  end

  class OcrElementConfig
    # Configuration for OCR element extraction.
    #
    # Controls how OCR elements are extracted and filtered.

    # Whether to include OCR elements in the extraction result.
    #
    # When true, the `ocr_elements` field in `ExtractionResult` will be populated.
    attr_accessor include_elements: bool?
    # Minimum hierarchical level to include.
    #
    # Elements below this level (e.g., words when min_level is Line) will be excluded.
    attr_accessor min_level: OcrElementLevel?
    # Minimum recognition confidence threshold (0.0-1.0).
    #
    # Elements with confidence below this threshold will be filtered out.
    attr_accessor min_confidence: Float?
    # Whether to build hierarchical relationships between elements.
    #
    # When true, `parent_id` fields will be populated based on spatial containment.
    # Only meaningful for Tesseract output.
    attr_accessor build_hierarchy: bool?

    def initialize: (include_elements: bool, min_level: OcrElementLevel, min_confidence: Float, build_hierarchy: bool) -> void
  end

  class PageStructure
    # Unified page structure for documents.
    #
    # Supports different page types (PDF pages, PPTX slides, Excel sheets)
    # with character offset boundaries for chunk-to-page mapping.

    # Total number of pages/slides/sheets
    attr_reader total_count: Integer
    # Type of paginated unit
    attr_reader unit_type: PageUnitType
    # Character offset boundaries for each page
    #
    # Maps character ranges in the extracted content to page numbers.
    # Used for chunk page range calculation.
    attr_reader boundaries: Array[PageBoundary]
    # Detailed per-page metadata (optional, only when needed)
    attr_reader pages: Array[PageInfo]

    def initialize: (total_count: Integer, unit_type: PageUnitType, ?boundaries: Array[PageBoundary], ?pages: Array[PageInfo]) -> void
  end

  class PageBoundary
    # Byte offset boundary for a page.
    #
    # Tracks where a specific page's content starts and ends in the main content string,
    # enabling mapping from byte positions to page numbers. Offsets are guaranteed to be
    # at valid UTF-8 character boundaries when using standard String methods (push_str, push, etc.).

    # Byte offset where this page starts in the content string (UTF-8 valid boundary, inclusive)
    attr_reader byte_start: Integer
    # Byte offset where this page ends in the content string (UTF-8 valid boundary, exclusive)
    attr_reader byte_end: Integer
    # Page number (1-indexed)
    attr_reader page_number: Integer

    def initialize: (byte_start: Integer, byte_end: Integer, page_number: Integer) -> void
  end

  class PageInfo
    # Metadata for individual page/slide/sheet.
    #
    # Captures per-page information including dimensions, content counts,
    # and visibility state (for presentations).

    # Page number (1-indexed)
    attr_reader number: Integer
    # Page title (usually for presentations)
    attr_reader title: String
    # Dimensions in points (PDF) or pixels (images): (width, height)
    attr_reader dimensions: Array[Float]
    # Number of images on this page
    attr_reader image_count: Integer
    # Number of tables on this page
    attr_reader table_count: Integer
    # Whether this page is hidden (e.g., in presentations)
    attr_reader hidden: bool
    # Whether this page is blank (no meaningful text, no images, no tables)
    #
    # A page is considered blank if it has fewer than 3 non-whitespace characters
    # and contains no tables or images. This is useful for filtering out empty pages
    # in scanned documents or PDFs with blank separator pages.
    attr_reader is_blank: bool
    # Whether this page contains non-trivial vector graphics (paths, shapes, curves)
    #
    # Indicates the presence of vector-drawn content such as charts, diagrams,
    # or geometric shapes (e.g., from Adobe InDesign, LaTeX TikZ). These are
    # invisible to `ExtractionResult.images` since they are not embedded as raster
    # XObjects. Set to `true` when path count exceeds a heuristic threshold,
    # signaling that downstream consumers may want to rasterize the page to
    # capture this content.
    #
    # Only populated for PDFs; `None` for other document types.
    attr_reader has_vector_graphics: bool

    def initialize: (number: Integer, ?title: String, ?dimensions: Array[Float], ?image_count: Integer, ?table_count: Integer, ?hidden: bool, ?is_blank: bool, has_vector_graphics: bool) -> void
  end

  class PageContent
    # Content for a single page/slide.
    #
    # When page extraction is enabled, documents are split into per-page content
    # with associated tables and images mapped to each page.
    #
    # # Performance
    #
    # Uses Arc-wrapped tables and images for memory efficiency:
    # - `Vec<Arc<Table>>` enables zero-copy sharing of table data
    # - `Vec<Arc<ExtractedImage>>` enables zero-copy sharing of image data
    # - Maintains exact JSON compatibility via custom Serialize/Deserialize
    #
    # This reduces memory overhead for documents with shared tables/images
    # by avoiding redundant copies during serialization.

    # Page number (1-indexed)
    attr_reader page_number: Integer
    # Text content for this page
    attr_reader content: String
    # Tables found on this page (uses Arc for memory efficiency)
    #
    # Serializes as Vec<Table> for JSON compatibility while maintaining
    # Arc semantics in-memory for zero-copy sharing.
    attr_reader tables: Array[Table]
    # Indices into `ExtractionResult.images` for images found on this page.
    #
    # Each value is a zero-based index into the top-level `images` collection.
    # Only populated when `extract_images = true` in the extraction config.
    attr_reader image_indices: Array[Integer]
    # Hierarchy information for the page (when hierarchy extraction is enabled)
    #
    # Contains text hierarchy levels (H1-H6) extracted from the page content.
    attr_reader hierarchy: PageHierarchy
    # Whether this page is blank (no meaningful text content)
    #
    # Determined during extraction based on text content analysis.
    # A page is blank if it has fewer than 3 non-whitespace characters
    # and contains no tables or images.
    attr_reader is_blank: bool
    # Layout detection regions for this page (when layout detection is enabled).
    #
    # Contains detected layout regions with class, confidence, bounding box,
    # and area fraction. Only populated when layout detection is configured.
    attr_reader layout_regions: Array[LayoutRegion]

    def initialize: (page_number: Integer, content: String, tables: Array[Table], image_indices: Array[Integer], ?hierarchy: PageHierarchy, ?is_blank: bool, ?layout_regions: Array[LayoutRegion]) -> void
  end

  class LayoutRegion
    # A detected layout region on a page.
    #
    # When layout detection is enabled, each page may have layout regions
    # identifying different content types (text, pictures, tables, etc.)
    # with confidence scores and spatial positions.

    # Layout class name (e.g. "picture", "table", "text", "section_header").
    attr_accessor class_name: String?
    # Confidence score from the layout detection model (0.0 to 1.0).
    attr_accessor confidence: Float?
    # Bounding box in document coordinate space.
    attr_accessor bounding_box: String?
    # Fraction of the page area covered by this region (0.0 to 1.0).
    attr_accessor area_fraction: Float?

    def initialize: (class_name: String, confidence: Float, bounding_box: String, area_fraction: Float) -> void
  end

  class PageHierarchy
    # Page hierarchy structure containing heading levels and block information.
    #
    # Used when PDF text hierarchy extraction is enabled. Contains hierarchical
    # blocks with heading levels (H1-H6) for semantic document structure.

    # Number of hierarchy blocks on this page
    attr_reader block_count: Integer
    # Hierarchical blocks with heading levels
    attr_reader blocks: Array[HierarchicalBlock]

    def initialize: (block_count: Integer, blocks: Array[HierarchicalBlock]) -> void
  end

  class HierarchicalBlock
    # A text block with hierarchy level assignment.
    #
    # Represents a block of text with semantic heading information extracted from
    # font size clustering and hierarchical analysis.

    # The text content of this block
    attr_reader text: String
    # The font size of the text in this block
    attr_reader font_size: Float
    # The hierarchy level of this block (H1-H6 or Body)
    #
    # Levels correspond to HTML heading tags:
    # - "h1": Top-level heading
    # - "h2": Secondary heading
    # - "h3": Tertiary heading
    # - "h4": Quaternary heading
    # - "h5": Quinary heading
    # - "h6": Senary heading
    # - "body": Body text (no heading level)
    attr_reader level: String
    # Bounding box information for the block
    #
    # Contains coordinates as (left, top, right, bottom) in PDF units.
    attr_reader bbox: Array[Float]

    def initialize: (text: String, font_size: Float, level: String, ?bbox: Array[Float]) -> void
  end

  class Table
    # Extracted table structure.
    #
    # Represents a table detected and extracted from a document (PDF, image, etc.).
    # Tables are converted to both structured cell data and Markdown format.

    # Table cells as a 2D vector (rows × columns)
    attr_accessor cells: Array[Array[String]]?
    # Markdown representation of the table
    attr_accessor markdown: String?
    # Page number where the table was found (1-indexed)
    attr_accessor page_number: Integer?
    # Bounding box of the table on the page (PDF coordinates: x0=left, y0=bottom, x1=right, y1=top).
    # Only populated for PDF-extracted tables when position data is available.
    attr_accessor bounding_box: String?

    def initialize: (cells: Array[Array[String]], markdown: String, page_number: Integer, ?bounding_box: String) -> void
  end

  class TableCell
    # Individual table cell with content and optional styling.
    #
    # Future extension point for rich table support with cell-level metadata.

    # Cell content as text
    attr_accessor content: String?
    # Row span (number of rows this cell spans)
    attr_accessor row_span: Integer?
    # Column span (number of columns this cell spans)
    attr_accessor col_span: Integer?
    # Whether this is a header cell
    attr_accessor is_header: bool?

    def initialize: (content: String, row_span: Integer, col_span: Integer, is_header: bool) -> void
  end

  class Uri
    # A URI extracted from a document.
    #
    # Represents any link, reference, or resource pointer found during extraction.
    # The `kind` field classifies the URI semantically, while `label` carries
    # optional human-readable display text.

    # The URL or path string.
    attr_reader url: String
    # Optional display text / label for the link.
    attr_reader label: String
    # Optional page number where the URI was found (1-indexed).
    attr_reader page: Integer
    # Semantic classification of the URI.
    attr_reader kind: UriKind

    def initialize: (url: String, ?label: String, ?page: Integer, kind: UriKind) -> void
  end

  class DetectResponse
    # MIME type detection response.

    # Detected MIME type
    attr_reader mime_type: String
    # Original filename (if provided)
    attr_reader filename: String

    def initialize: (mime_type: String, ?filename: String) -> void
  end

  class EmbeddingPreset
    # Preset configurations for common RAG use cases.
    #
    # Each preset combines chunk size, overlap, and embedding model
    # to provide an optimized configuration for specific scenarios.
    #
    # All string fields are owned `String` for FFI compatibility — instances
    # are safe to clone and pass across language boundaries.

    attr_reader name: String
    attr_reader chunk_size: Integer
    attr_reader overlap: Integer
    # HuggingFace repository name for the model.
    attr_reader model_repo: String
    # Pooling strategy: "cls" or "mean".
    attr_reader pooling: String
    # Path to the ONNX model file within the repo.
    attr_reader model_file: String
    attr_reader dimensions: Integer
    attr_reader description: String

    def initialize: (name: String, chunk_size: Integer, overlap: Integer, model_repo: String, pooling: String, model_file: String, dimensions: Integer, description: String) -> void
  end

  class YakeParams
    # YAKE-specific parameters.

    # Window size for co-occurrence analysis (default: 2).
    #
    # Controls the context window for computing co-occurrence statistics.
    attr_accessor window_size: Integer?

    def initialize: (window_size: Integer) -> void
    def self.default: () -> YakeParams
  end

  class RakeParams
    # RAKE-specific parameters.

    # Minimum word length to consider (default: 1).
    attr_accessor min_word_length: Integer?
    # Maximum words in a keyword phrase (default: 3).
    attr_accessor max_words_per_phrase: Integer?

    def initialize: (min_word_length: Integer, max_words_per_phrase: Integer) -> void
    def self.default: () -> RakeParams
  end

  class KeywordConfig
    # Keyword extraction configuration.

    # Algorithm to use for extraction.
    attr_accessor algorithm: KeywordAlgorithm?
    # Maximum number of keywords to extract (default: 10).
    attr_accessor max_keywords: Integer?
    # Minimum score threshold (0.0-1.0, default: 0.0).
    #
    # Keywords with scores below this threshold are filtered out.
    # Note: Score ranges differ between algorithms.
    attr_accessor min_score: Float?
    # N-gram range for keyword extraction (min, max).
    #
    # (1, 1) = unigrams only
    # (1, 2) = unigrams and bigrams
    # (1, 3) = unigrams, bigrams, and trigrams (default)
    attr_accessor ngram_range: Array[Integer]?
    # Language code for stopword filtering (e.g., "en", "de", "fr").
    #
    # If None, no stopword filtering is applied.
    attr_accessor language: String?
    # YAKE-specific tuning parameters.
    attr_accessor yake_params: YakeParams?
    # RAKE-specific tuning parameters.
    attr_accessor rake_params: RakeParams?

    def initialize: (algorithm: KeywordAlgorithm, max_keywords: Integer, min_score: Float, ngram_range: Array[Integer], ?language: String, ?yake_params: YakeParams, ?rake_params: RakeParams) -> void
    def self.default: () -> KeywordConfig
  end

  class Keyword
    # Extracted keyword with metadata.

    # The keyword text.
    attr_reader text: String
    # Relevance score (higher is better, algorithm-specific range).
    attr_reader score: Float
    # Algorithm that extracted this keyword.
    attr_reader algorithm: KeywordAlgorithm
    # Optional positions where keyword appears in text (character offsets).
    attr_reader positions: Array[Integer]

    def initialize: (text: String, score: Float, algorithm: KeywordAlgorithm, ?positions: Array[Integer]) -> void
  end

  class OcrCacheStats
    attr_accessor total_files: Integer?
    attr_accessor total_size_mb: Float?

    def initialize: (total_files: Integer, total_size_mb: Float) -> void
  end

  class PaddleOcrConfig
    # Configuration for PaddleOCR backend.
    #
    # Configures PaddleOCR text detection and recognition with multi-language support.
    # Uses a builder pattern for convenient configuration.
    #
    # # Examples
    #
    # ```no_run
    # use kreuzberg::PaddleOcrConfig;
    #
    # // Create with default English configuration
    # let config = PaddleOcrConfig::new("en");
    #
    # // Create with custom cache directory
    # let config = PaddleOcrConfig::new("ch")
    #     .with_cache_dir("/path/to/cache".into());
    #
    # // Enable table detection
    # let config = PaddleOcrConfig::new("en")
    #     .with_table_detection(true);
    # ```

    # Language code (e.g., "en", "ch", "jpn", "kor", "deu", "fra")
    attr_accessor language: String?
    # Optional custom cache directory for model files
    attr_accessor cache_dir: String?
    # Enable angle classification for rotated text (default: false).
    # Can misfire on short text regions, rotating crops incorrectly before recognition.
    attr_accessor use_angle_cls: bool?
    # Enable table structure detection (default: false)
    attr_accessor enable_table_detection: bool?
    # Database threshold for text detection (default: 0.3)
    # Range: 0.0-1.0, higher values require more confident detections
    attr_accessor det_db_thresh: Float?
    # Box threshold for text bounding box refinement (default: 0.5)
    # Range: 0.0-1.0
    attr_accessor det_db_box_thresh: Float?
    # Unclip ratio for expanding text bounding boxes (default: 1.6)
    # Controls the expansion of detected text regions
    attr_accessor det_db_unclip_ratio: Float?
    # Maximum side length for detection image (default: 960)
    # Larger images may be resized to this limit for faster inference
    attr_accessor det_limit_side_len: Integer?
    # Batch size for recognition inference (default: 6)
    # Number of text regions to process simultaneously
    attr_accessor rec_batch_num: Integer?
    # Padding in pixels added around the image before detection (default: 10).
    # Large values can include surrounding content like table gridlines.
    attr_accessor padding: Integer?
    # Minimum recognition confidence score for text lines (default: 0.5).
    # Text regions with recognition confidence below this threshold are discarded.
    # Matches PaddleOCR Python's `drop_score` parameter.
    # Range: 0.0-1.0
    attr_accessor drop_score: Float?
    # Model tier controlling detection/recognition model size and accuracy trade-off.
    # - `"mobile"` (default): Lightweight models (~4.5MB detection, ~16.5MB recognition), fast download and inference
    # - `"server"`: Large, high-accuracy models (~88MB detection, ~84MB recognition), best for GPU or complex documents
    attr_accessor model_tier: String?

    def initialize: (language: String, ?cache_dir: String, use_angle_cls: bool, enable_table_detection: bool, det_db_thresh: Float, det_db_box_thresh: Float, det_db_unclip_ratio: Float, det_limit_side_len: Integer, rec_batch_num: Integer, padding: Integer, drop_score: Float, model_tier: String) -> void
    # Sets a custom cache directory for model files.
    #
    # # Arguments
    #
    # * `path` - Path to cache directory
    #
    # # Examples
    #
    # ```no_run
    # use kreuzberg::PaddleOcrConfig;
    # use std::path::PathBuf;
    #
    # let config = PaddleOcrConfig::new("en")
    # .with_cache_dir(PathBuf::from("/tmp/paddle-cache"));
    # ```
    def with_cache_dir: (String path) -> PaddleOcrConfig
    # Enables or disables table structure detection.
    #
    # # Arguments
    #
    # * `enable` - Whether to enable table detection
    #
    # # Examples
    #
    # ```no_run
    # use kreuzberg::PaddleOcrConfig;
    #
    # let config = PaddleOcrConfig::new("en")
    # .with_table_detection(true);
    # ```
    def with_table_detection: (bool enable) -> PaddleOcrConfig
    # Enables or disables angle classification for rotated text.
    #
    # # Arguments
    #
    # * `enable` - Whether to enable angle classification
    def with_angle_cls: (bool enable) -> PaddleOcrConfig
    # Sets the database threshold for text detection.
    #
    # # Arguments
    #
    # * `threshold` - Detection threshold (0.0-1.0)
    def with_det_db_thresh: (Float threshold) -> PaddleOcrConfig
    # Sets the box threshold for text bounding box refinement.
    #
    # # Arguments
    #
    # * `threshold` - Box threshold (0.0-1.0)
    def with_det_db_box_thresh: (Float threshold) -> PaddleOcrConfig
    # Sets the unclip ratio for expanding text bounding boxes.
    #
    # # Arguments
    #
    # * `ratio` - Unclip ratio (typically 1.5-2.0)
    def with_det_db_unclip_ratio: (Float ratio) -> PaddleOcrConfig
    # Sets the maximum side length for detection images.
    #
    # # Arguments
    #
    # * `length` - Maximum side length in pixels
    def with_det_limit_side_len: (Integer length) -> PaddleOcrConfig
    # Sets the batch size for recognition inference.
    #
    # # Arguments
    #
    # * `batch_size` - Number of text regions to process simultaneously
    def with_rec_batch_num: (Integer batch_size) -> PaddleOcrConfig
    # Sets the minimum recognition confidence threshold.
    #
    # # Arguments
    #
    # * `score` - Minimum confidence (0.0-1.0), text below this is dropped
    def with_drop_score: (Float score) -> PaddleOcrConfig
    # Sets padding in pixels added around images before detection.
    #
    # # Arguments
    #
    # * `padding` - Padding in pixels (0-100)
    def with_padding: (Integer padding) -> PaddleOcrConfig
    # Sets the model tier controlling detection/recognition model size.
    #
    # # Arguments
    #
    # * `tier` - `"mobile"` (default, lightweight, faster) or `"server"` (high accuracy, GPU/complex documents)
    def with_model_tier: (String tier) -> PaddleOcrConfig
    # Creates a default configuration with English language support.
    def self.default: () -> PaddleOcrConfig
  end

  class ModelPaths
    # Combined paths to all models needed for OCR (backward compatibility).

    # Path to the detection model directory.
    attr_reader det_model: String
    # Path to the classification model directory.
    attr_reader cls_model: String
    # Path to the recognition model directory.
    attr_reader rec_model: String
    # Path to the character dictionary file.
    attr_reader dict_file: String

    def initialize: (det_model: String, cls_model: String, rec_model: String, dict_file: String) -> void
  end

  class OrientationResult
    # Document orientation detection result.

    # Detected orientation in degrees (0, 90, 180, or 270).
    attr_reader degrees: Integer
    # Confidence score (0.0-1.0).
    attr_reader confidence: Float

    def initialize: (degrees: Integer, confidence: Float) -> void
  end

  class BBox
    # Bounding box in original image coordinates (x1, y1) top-left, (x2, y2) bottom-right.

    attr_reader x1: Float
    attr_reader y1: Float
    attr_reader x2: Float
    attr_reader y2: Float

    def initialize: (x1: Float, y1: Float, x2: Float, y2: Float) -> void
  end

  class LayoutDetection
    # A single layout detection result.

    attr_reader class_name: LayoutClass
    attr_reader confidence: Float
    attr_reader bbox: BBox

    def initialize: (class_name: LayoutClass, confidence: Float, bbox: BBox) -> void
  end

  class RecognizedTable
    # Pre-computed table markdown for a table detection region.
    #
    # Produced by the TATR-based table structure recognizer and surfaced as part of
    # layout-aware OCR results.  The struct lives here (under `layout-types`, pure-Rust)
    # so that consumers who do not enable `layout-detection` (ORT) can still reference
    # the type in their own code.

    # Detection bbox that this table corresponds to (for matching).
    attr_reader detection_bbox: BBox
    # Table cells as a 2D vector (rows × columns).
    attr_reader cells: Array[Array[String]]
    # Rendered markdown table.
    attr_reader markdown: String

    def initialize: (detection_bbox: BBox, cells: Array[Array[String]], markdown: String) -> void
  end

  class DetectionResult
    # Page-level detection result containing all detections and page metadata.

    attr_reader page_width: Integer
    attr_reader page_height: Integer
    attr_reader detections: Array[LayoutDetection]

    def initialize: (page_width: Integer, page_height: Integer, detections: Array[LayoutDetection]) -> void
  end

  class EmbeddedFile
    # Embedded file descriptor extracted from the PDF name tree.

    # The filename as stored in the PDF name tree.
    attr_reader name: String
    # Raw file bytes from the embedded stream.
    attr_reader data: String
    # MIME type if specified in the filespec, otherwise `None`.
    attr_reader mime_type: String

    def initialize: (name: String, data: String, ?mime_type: String) -> void
  end

  class PdfMetadata
    # PDF-specific metadata.
    #
    # Contains metadata fields specific to PDF documents that are not in the common
    # `Metadata` structure. Common fields like title, authors, keywords, and dates
    # are at the `Metadata` level.

    # PDF version (e.g., "1.7", "2.0")
    attr_accessor pdf_version: String?
    # PDF producer (application that created the PDF)
    attr_accessor producer: String?
    # Whether the PDF is encrypted/password-protected
    attr_accessor is_encrypted: bool?
    # First page width in points (1/72 inch)
    attr_accessor width: Integer?
    # First page height in points (1/72 inch)
    attr_accessor height: Integer?
    # Total number of pages in the PDF document
    attr_accessor page_count: Integer?

    def initialize: (?pdf_version: String, ?producer: String, ?is_encrypted: bool, ?width: Integer, ?height: Integer, ?page_count: Integer) -> void
  end

  class ExecutionProviderType
    # ONNX Runtime execution provider type.
    #
    # Determines which hardware backend is used for model inference.
    # `Auto` (default) selects the best available provider per platform.
    type value = :auto | :cpu | :core_ml | :cuda | :tensor_rt
  end

  class OutputFormat
    # Output format for extraction results.
    #
    # Controls the format of the `content` field in `ExtractionResult`.
    # When set to `Markdown`, `Djot`, or `Html`, the output will be formatted
    # accordingly. `Plain` returns the raw extracted text.
    # `Structured` returns JSON with full OCR element data including bounding
    # boxes and confidence scores.
  end

  class HtmlTheme
    # Built-in HTML theme selection.
    type value = :default | :git_hub | :dark | :light | :unstyled
  end

  class TableModel
    # Which table structure recognition model to use.
    #
    # Controls the model used for table cell detection within layout-detected
    # table regions. Wire format is snake_case in all serializers (JSON, TOML,
    # YAML).
    type value = :tatr | :slanet_wired | :slanet_wireless | :slanet_plus | :slanet_auto | :disabled
  end

  class ChunkerType
    # Type of text chunker to use.
    #
    # # Variants
    #
    # * `Text` - Generic text splitter, splits on whitespace and punctuation
    # * `Markdown` - Markdown-aware splitter, preserves formatting and structure
    # * `Yaml` - YAML-aware splitter, creates one chunk per top-level key
    # * `Semantic` - Topic-aware chunker. With an `EmbeddingConfig`, splits at
    #   embedding-based topic shifts tuned by `topic_threshold` (default 0.75,
    #   lower = more splits). Without an embedding, falls back to a
    #   structural-boundary heuristic (ALL-CAPS headers, numbered sections,
    #   blank-line paragraphs) and merges groups into chunks capped at
    #   `max_characters` (default 1000). `topic_threshold` has no effect in the
    #   fallback path. For best results, pair with an embedding model.
    type value = :text | :markdown | :yaml | :semantic
  end

  class ChunkSizing
    # How chunk size is measured.
    #
    # Defaults to `Characters` (Unicode character count). When using token-based sizing,
    # chunks are sized by token count according to the specified tokenizer.
    #
    # Token-based sizing uses HuggingFace tokenizers loaded at runtime. Any tokenizer
    # available on HuggingFace Hub can be used, including OpenAI-compatible tokenizers
    # (e.g., `Xenova/gpt-4o`, `Xenova/cl100k_base`).
  end

  class EmbeddingModelType
    # Embedding model types supported by Kreuzberg.
  end

  class CodeContentMode
    # Content rendering mode for code extraction.
    #
    # Controls how extracted code content is represented in the `content` field
    # of `ExtractionResult`.
    type value = :chunks | :raw | :structure
  end

  class ListType
    # Type of list detection.
    type value = :bullet | :numbered | :lettered | :indented
  end

  class DrawingType
    # Whether the drawing is inline or anchored.
  end

  class FracType
    type value = :bar | :no_bar | :linear | :skewed
  end

  class OcrBackendType
    # OCR backend types.
    type value = :tesseract | :easy_o_c_r | :paddle_o_c_r | :custom
  end

  class ProcessingStage
    # Processing stages for post-processors.
    #
    # Post-processors are executed in stage order (Early → Middle → Late).
    # Use stages to control the order of post-processing operations.
    type value = :early | :middle | :late
  end

  class ReductionLevel
    type value = :off | :light | :moderate | :aggressive | :maximum
  end

  class PdfAnnotationType
    # Type of PDF annotation.
    type value = :text | :highlight | :link | :stamp | :underline | :strike_out | :other
  end

  class BlockType
    # Types of block-level elements in Djot.
    type value = :paragraph | :heading | :blockquote | :code_block | :list_item | :ordered_list | :bullet_list | :task_list | :definition_list | :definition_term | :definition_description | :div | :section | :thematic_break | :raw_block | :math_display
  end

  class InlineType
    # Types of inline elements in Djot.
    type value = :text | :strong | :emphasis | :highlight | :subscript | :superscript | :insert | :delete | :code | :link | :image | :span | :math | :raw_inline | :footnote_ref | :symbol
  end

  class RelationshipKind
    # Semantic kind of a relationship between document elements.
    type value = :footnote_reference | :citation_reference | :internal_link | :caption | :label | :toc_entry | :cross_reference
  end

  class ContentLayer
    # Content layer classification for document nodes.
    #
    # Replaces separate body/furniture arrays with per-node granularity.
    type value = :body | :header | :footer | :footnote
  end

  class NodeContent
    # Tagged enum for node content. Each variant carries only type-specific data.
    #
    # Uses `#[serde(tag = "node_type")]` to avoid "type" keyword collision in
    # Go/Java/TypeScript bindings.
  end

  class AnnotationKind
    # Types of inline text annotations.
  end

  class ExtractionMethod
    # How the extracted text was produced.
    type value = :native | :ocr | :mixed
  end

  class ChunkType
    # Semantic structural classification of a text chunk.
    #
    # Assigned by the heuristic classifier in `chunking::classifier`.
    # Defaults to `Unknown` when no rule matches.
    # Designed to be extended in future versions without breaking changes.
    type value = :heading | :party_list | :definitions | :operative_clause | :signature_block | :schedule | :table_like | :formula | :code_block | :image | :org_chart | :diagram | :unknown
  end

  class ImageKind
    # Heuristic classification of what an image likely depicts.
    type value = :photograph | :diagram | :chart | :drawing | :text_block | :decoration | :logo | :icon | :tile_fragment | :mask | :unknown
  end

  class ResultFormat
    # Result-shape selection for extraction results.
    #
    # Distinct from `OutputFormat` (which controls rendering — Plain, Markdown,
    # HTML, etc.). `ResultFormat` controls the *shape* of the result: a unified content
    # blob vs. an element-based decomposition.
    type value = :unified | :element_based
  end

  class ElementType
    # Semantic element type classification.
    #
    # Categorizes text content into semantic units for downstream processing.
    # Supports the element types commonly found in Unstructured documents.
    type value = :title | :narrative_text | :heading | :list_item | :table | :image | :page_break | :code_block | :block_quote | :footer | :header
  end

  class FormatMetadata
    # Format-specific metadata (discriminated union).
    #
    # Only one format type can exist per extraction result. This provides
    # type-safe, clean metadata without nested optionals.
  end

  class TextDirection
    # Text direction enumeration for HTML documents.
    type value = :left_to_right | :right_to_left | :auto
  end

  class LinkType
    # Link type classification.
    type value = :anchor | :internal | :external | :email | :phone | :other
  end

  class ImageType
    # Image type classification.
    type value = :data_uri | :inline_svg | :external | :relative
  end

  class StructuredDataType
    # Structured data type classification.
    type value = :json_ld | :microdata | :r_d_fa
  end

  class OcrBoundingGeometry
    # Bounding geometry for an OCR element.
    #
    # Supports both axis-aligned rectangles (from Tesseract) and 4-point quadrilaterals
    # (from PaddleOCR and rotated text detection).
  end

  class OcrElementLevel
    # Hierarchical level of an OCR element.
    #
    # Maps to Tesseract's page segmentation hierarchy and provides
    # equivalent semantics for PaddleOCR.
    type value = :word | :line | :block | :page
  end

  class PageUnitType
    # Type of paginated unit in a document.
    #
    # Distinguishes between different types of "pages" (PDF pages, presentation slides, spreadsheet sheets).
    type value = :page | :slide | :sheet
  end

  class UriKind
    # Semantic classification of an extracted URI.
    type value = :hyperlink | :image | :anchor | :citation | :reference | :email
  end

  class KeywordAlgorithm
    # Keyword algorithm selection.
    type value = :yake | :rake
  end

  class PSMMode
    # Page Segmentation Mode for Tesseract OCR
    type value = :osd_only | :auto_osd | :auto_only | :auto | :single_column | :single_block_vertical | :single_block | :single_line | :single_word | :circle_word | :single_char
  end

  class PaddleLanguage
    # Supported languages in PaddleOCR.
    #
    # Maps user-friendly language codes to paddle-ocr-rs language identifiers.
    type value = :english | :chinese | :japanese | :korean | :german | :french | :latin | :cyrillic | :traditional_chinese | :thai | :greek | :east_slavic | :arabic | :devanagari | :tamil | :telugu
  end

  class LayoutClass
    # The 17 canonical document layout classes.
    #
    # All model backends (RT-DETR, YOLO, etc.) map their native class IDs
    # to this shared set. Models with fewer classes (DocLayNet: 11, PubLayNet: 5)
    # map to the closest equivalent.
    #
    # Wire format is snake_case in all serializers (JSON, TOML, YAML).
    type value = :caption | :footnote | :formula | :list_item | :page_footer | :page_header | :picture | :section_header | :table | :text | :title | :document_index | :code | :checkbox_selected | :checkbox_unselected | :form | :key_value_region
  end

  def self.extract_bytes: (String content, String mime_type, ExtractionConfig config) -> ExtractionResult

  def self.extract_file: (String path, ?String mime_type, ExtractionConfig config) -> ExtractionResult

  def self.extract_file_sync: (String path, ?String mime_type, ExtractionConfig config) -> ExtractionResult

  def self.extract_bytes_sync: (String content, String mime_type, ExtractionConfig config) -> ExtractionResult

  def self.batch_extract_files_sync: (Array[BatchFileItem] items, ExtractionConfig config) -> Array[ExtractionResult]

  def self.batch_extract_bytes_sync: (Array[BatchBytesItem] items, ExtractionConfig config) -> Array[ExtractionResult]

  def self.batch_extract_files: (Array[BatchFileItem] items, ExtractionConfig config) -> Array[ExtractionResult]

  def self.batch_extract_bytes: (Array[BatchBytesItem] items, ExtractionConfig config) -> Array[ExtractionResult]

  def self.detect_mime_type_from_bytes: (String content) -> String

  def self.get_extensions_for_mime: (String mime_type) -> Array[String]

  def self.list_embedding_backends: () -> Array[String]

  def self.list_document_extractors: () -> Array[String]

  def self.list_ocr_backends: () -> Array[String]

  def self.list_post_processors: () -> Array[String]

  def self.list_renderers: () -> Array[String]

  def self.list_validators: () -> Array[String]

  def self.embed_texts_async: (Array[String] texts, EmbeddingConfig config) -> Array[Array[Float]]

  def self.render_pdf_page_to_png: (String pdf_bytes, Integer page_index, ?Integer dpi, ?String password) -> String

  def self.detect_mime_type: (String path, bool check_exists) -> String

  def self.embed_texts: (Array[String] texts, EmbeddingConfig config) -> Array[Array[Float]]

  def self.get_embedding_preset: (String name) -> EmbeddingPreset?

  def self.list_embedding_presets: () -> Array[String]

end
