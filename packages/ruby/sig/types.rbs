    attr_accessor license: String?
    attr_accessor history_dates: Hash[String, String]?
    attr_accessor contributor_roles: Array[ContributorRole]?

    def initialize: (?copyright: String, ?license: String, history_dates: Hash[String, String], contributor_roles: Array[ContributorRole]) -> void
