    attr_accessor from_email: String?
    # Sender's display name
    attr_accessor from_name: String?
    # Primary recipients
    attr_accessor to_emails: Array[String]?
    # CC recipients
    attr_accessor cc_emails: Array[String]?
    # BCC recipients
    attr_accessor bcc_emails: Array[String]?
    # Message-ID header value
    attr_accessor message_id: String?
    # List of attachment filenames
    attr_accessor attachments: Array[String]?

    def initialize: (?from_email: String, ?from_name: String, to_emails: Array[String], cc_emails: Array[String], bcc_emails: Array[String], ?message_id: String, attachments: Array[String]) -> void
  end

  class ArchiveMetadata
    # Archive (ZIP/TAR/7Z) metadata.
