  class SecurityLimits
    # Configuration for security limits across extractors.
    #
    # All limits are intentionally conservative to prevent DoS attacks
    # while still supporting legitimate documents.

    # Maximum uncompressed size for archives (500 MB)
    attr_accessor max_archive_size: Integer?
    # Maximum compression ratio before flagging as potential bomb (100:1)
    attr_accessor max_compression_ratio: Integer?
    # Maximum number of files in archive (10,000)
    attr_accessor max_files_in_archive: Integer?
    # Maximum nesting depth for structures (100)
    attr_accessor max_nesting_depth: Integer?
    # Maximum length of any single XML entity / attribute / token (1 MiB).
    # This is a per-token cap, NOT a cumulative cap — billion-laughs class
    # attacks where a single entity expands to hundreds of MB are caught
    # here, while normal long text content (a paragraph, a CDATA block) is
    # caught by `max_content_size` instead.
    attr_accessor max_entity_length: Integer?
    # Maximum string growth per document (100 MB)
    attr_accessor max_content_size: Integer?
    # Maximum iterations per operation
    attr_accessor max_iterations: Integer?
    # Maximum XML depth (100 levels)
    attr_accessor max_xml_depth: Integer?
    # Maximum cells per table (100,000)
    attr_accessor max_table_cells: Integer?

    def initialize: (max_archive_size: Integer, max_compression_ratio: Integer, max_files_in_archive: Integer, max_nesting_depth: Integer, max_entity_length: Integer, max_content_size: Integer, max_iterations: Integer, max_xml_depth: Integer, max_table_cells: Integer) -> void
    def self.default: () -> SecurityLimits
  end

