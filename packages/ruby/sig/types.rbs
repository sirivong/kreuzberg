  end

  class TextMetadata
    # Text/Markdown metadata.
    #
    # Extracted from plain text and Markdown files. Includes word counts and,
    # for Markdown, structural elements like headers and links.

    # Number of lines in the document
    attr_accessor line_count: Integer?
    # Number of words
    attr_accessor word_count: Integer?
    # Number of characters
    attr_accessor character_count: Integer?
    # Markdown headers (headings text only, for Markdown files)
    attr_accessor headers: Array[String]?
    # Markdown links as (text, url) tuples (for Markdown files)
    attr_accessor links: Array[String]?
    # Code blocks as (language, code) tuples (for Markdown files)
    attr_accessor code_blocks: Array[String]?

    def initialize: (line_count: Integer, word_count: Integer, character_count: Integer, ?headers: Array[String], ?links: Array[String], ?code_blocks: Array[String]) -> void
  end

  class HeaderMetadata
    # Header/heading element metadata.

    # Header level: 1 (h1) through 6 (h6)
    attr_reader level: Integer
    # Normalized text content of the header
    attr_reader text: String
    # HTML id attribute if present
    attr_reader id: String
    # Document tree depth at the header element
    attr_reader depth: Integer
    # Byte offset in original HTML document
    attr_reader html_offset: Integer

    def initialize: (level: Integer, text: String, ?id: String, depth: Integer, html_offset: Integer) -> void
  end

  class LinkMetadata
    # Link element metadata.

    # The href URL value
    attr_reader href: String
    # Link text content (normalized)
    attr_reader text: String
    # Optional title attribute
    attr_reader title: String
    # Link type classification
    attr_reader link_type: LinkType
    # Rel attribute values
    attr_reader rel: Array[String]
    # Additional attributes as key-value pairs
    attr_reader attributes: Array[String]

    def initialize: (href: String, text: String, ?title: String, link_type: LinkType, rel: Array[String], attributes: Array[String]) -> void
  end

  class ImageMetadataType
    # Image element metadata.

    # Image source (URL, data URI, or SVG content)
    attr_reader src: String
    # Alternative text from alt attribute
    attr_reader alt: String
    # Title attribute
    attr_reader title: String
    # Image dimensions as (width, height) if available
    attr_reader dimensions: Array[Integer]
    # Image type classification
    attr_reader image_type: ImageType
    # Additional attributes as key-value pairs
    attr_reader attributes: Array[String]

    def initialize: (src: String, ?alt: String, ?title: String, ?dimensions: Array[Integer], image_type: ImageType, attributes: Array[String]) -> void
  end

  class StructuredData
    # Structured data (Schema.org, microdata, RDFa) block.

    # Type of structured data
    attr_reader data_type: StructuredDataType
    # Raw JSON string representation
    attr_reader raw_json: String
    # Schema type if detectable (e.g., "Article", "Event", "Product")
    attr_reader schema_type: String

    def initialize: (data_type: StructuredDataType, raw_json: String, ?schema_type: String) -> void
  end

  class HtmlMetadata
    # HTML metadata extracted from HTML documents.
    #
    # Includes document-level metadata, Open Graph data, Twitter Card metadata,
    # and extracted structural elements (headers, links, images, structured data).

    # Document title from `<title>` tag
    attr_accessor title: String?
    # Document description from `<meta name="description">` tag
    attr_accessor description: String?
    # Document keywords from `<meta name="keywords">` tag, split on commas
    attr_accessor keywords: Array[String]?
    # Document author from `<meta name="author">` tag
    attr_accessor author: String?
    # Canonical URL from `<link rel="canonical">` tag
    attr_accessor canonical_url: String?
    # Base URL from `<base href="">` tag for resolving relative URLs
    attr_accessor base_href: String?
    # Document language from `lang` attribute
    attr_accessor language: String?
    # Document text direction from `dir` attribute
    attr_accessor text_direction: TextDirection?
    # Open Graph metadata (og:* properties) for social media
    # Keys like "title", "description", "image", "url", etc.
    attr_accessor open_graph: Hash[String, String]?
    # Twitter Card metadata (twitter:* properties)
    # Keys like "card", "site", "creator", "title", "description", "image", etc.
    attr_accessor twitter_card: Hash[String, String]?
    # Additional meta tags not covered by specific fields
    # Keys are meta name/property attributes, values are content
    attr_accessor meta_tags: Hash[String, String]?
    # Extracted header elements with hierarchy
    attr_accessor headers: Array[HeaderMetadata]?
    # Extracted hyperlinks with type classification
    attr_accessor links: Array[LinkMetadata]?
    # Extracted images with source and dimensions
    attr_accessor images: Array[ImageMetadataType]?
    # Extracted structured data blocks
    attr_accessor structured_data: Array[StructuredData]?

    def initialize: (?title: String, ?description: String, keywords: Array[String], ?author: String, ?canonical_url: String, ?base_href: String, ?language: String, ?text_direction: TextDirection, open_graph: Hash[String, String], twitter_card: Hash[String, String], meta_tags: Hash[String, String], headers: Array[HeaderMetadata], links: Array[LinkMetadata], images: Array[ImageMetadataType], structured_data: Array[StructuredData]) -> void
    def self.from: (HtmlMetadata metadata) -> HtmlMetadata
  end

  class OcrMetadata
    # OCR processing metadata.
