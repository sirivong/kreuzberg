  class DocumentStructure
    # Top-level structured document representation.
    #
    # A flat array of nodes with index-based parent/child references forming a tree.
    # Root-level nodes have `parent: None`. Use `body_roots()` and `furniture_roots()`
    # to iterate over top-level content by layer.
    #
    # # Validation
    #
    # Call `validate()` after construction to verify all node indices are in bounds
    # and parent-child relationships are bidirectionally consistent.

    # All nodes in document/reading order.
    attr_accessor nodes: Array[DocumentNode]?
    # Origin format identifier (e.g. "docx", "pptx", "html", "pdf").
    #
    # Allows renderers to apply format-aware heuristics when converting
    # the document tree to output formats.
    attr_accessor source_format: String?
    # Resolved relationships between nodes (footnote refs, citations, anchor links, etc.).
    #
    # Populated during derivation from the internal document representation.
    # Empty when no relationships are detected.
    attr_accessor relationships: Array[DocumentRelationship]?
    # Sorted, deduplicated list of node type names present in this document.
    #
    # Each value is the snake_case `node_type` tag of the corresponding
    # [`NodeContent`] variant (e.g. `"paragraph"`, `"heading"`, `"table"`, …).
    #
    # Computed from [`nodes`] via [`DocumentStructure::finalize_node_types`].
    # Empty until that method is called (internal construction paths call it
    # at the end of derivation).
    attr_accessor node_types: Array[String]?

    def initialize: (nodes: Array[DocumentNode], ?source_format: String, relationships: Array[DocumentRelationship], node_types: Array[String]) -> void
    # Compute and populate the `node_types` field from the current `nodes`.
    #
    # Call this after all nodes have been added to the structure. Internal
    # construction paths (builder, derivation) call this automatically.
    #
    # # Examples
    #
    # ```rust
    # use kreuzberg::types::document_structure::{DocumentStructure, DocumentNode, NodeContent, NodeId};
    #
    # let mut structure = DocumentStructure {
    # nodes: vec![DocumentNode {
    # id: NodeId::from("n1"),
    # content: NodeContent::Paragraph { text: "Hello".into() },
    # parent: None,
    # children: vec![],
    # content_layer: Default::default(),
    # page: None,
    # page_end: None,
    # bbox: None,
    # annotations: vec![],
    # attributes: None,
    # }],
    # source_format: None,
    # relationships: vec![],
    # node_types: vec![],
    # };
    # structure.finalize_node_types();
    # assert!(structure.node_types.contains(&"paragraph".to_string()));
    # ```
    def finalize_node_types: () -> void
    # Check if the document structure is empty.
    def is_empty: () -> bool
    def self.default: () -> DocumentStructure
  end

  class DocumentRelationship
    # A resolved relationship between two nodes in the document tree.

    # Source node index (the referencing node).
    attr_reader source: Integer
    # Target node index (the referenced node).
    attr_reader target: Integer
    # Semantic kind of the relationship.
    attr_reader kind: RelationshipKind

    def initialize: (source: Integer, target: Integer, kind: RelationshipKind) -> void
  end

  class DocumentNode
    # A single node in the document tree.
    #
    # Each node has deterministic `id`, typed `content`, optional `parent`/`children`
    # for tree structure, and metadata like page number, bounding box, and content layer.

    # Deterministic identifier (hash of content + position).
    attr_reader id: String
    # Node content — tagged enum, type-specific data only.
    attr_reader content: NodeContent
    # Parent node index (`None` = root-level node).
    attr_reader parent: Integer
    # Child node indices in reading order.
    attr_reader children: Array[Integer]
    # Content layer classification.
    attr_reader content_layer: ContentLayer
    # Page number where this node starts (1-indexed).
    attr_reader page: Integer
    # Page number where this node ends (for multi-page tables/sections).
    attr_reader page_end: Integer
    # Bounding box in document coordinates.
    attr_reader bbox: String
    # Inline annotations (formatting, links) on this node's text content.
    #
    # Only meaningful for text-carrying nodes; empty for containers.
    attr_reader annotations: Array[TextAnnotation]
    # Format-specific key-value attributes.
    #
    # Extensible bag for data that doesn't warrant a typed field: CSS classes,
    # LaTeX environment names, Excel cell formulas, slide layout names, etc.
    attr_reader attributes: Hash[String, String]

    def initialize: (id: String, content: NodeContent, ?parent: Integer, children: Array[Integer], content_layer: ContentLayer, ?page: Integer, ?page_end: Integer, ?bbox: String, annotations: Array[TextAnnotation], ?attributes: Hash[String, String]) -> void
  end

  class TableGrid
    # Structured table grid with cell-level metadata.
    #
    # Stores row/column dimensions and a flat list of cells with position info.

    # Number of rows in the table.
    attr_accessor rows: Integer?
    # Number of columns in the table.
    attr_accessor cols: Integer?
    # All cells in row-major order.
    attr_accessor cells: Array[GridCell]?

    def initialize: (rows: Integer, cols: Integer, cells: Array[GridCell]) -> void
  end

  class GridCell
    # Individual grid cell with position and span metadata.

    # Cell text content.
    attr_reader content: String
    # Zero-indexed row position.
    attr_reader row: Integer
    # Zero-indexed column position.
    attr_reader col: Integer
    # Number of rows this cell spans.
    attr_reader row_span: Integer
    # Number of columns this cell spans.
    attr_reader col_span: Integer
    # Whether this is a header cell.
    attr_reader is_header: bool
    # Bounding box for this cell (if available).
    attr_reader bbox: String

    def initialize: (content: String, row: Integer, col: Integer, row_span: Integer, col_span: Integer, is_header: bool, ?bbox: String) -> void
  end

  class TextAnnotation
    # Inline text annotation — byte-range based formatting and links.
    #
    # Annotations reference byte offsets into the node's text content,
    # enabling precise identification of formatted regions.

    # Start byte offset in the node's text content (inclusive).
    attr_reader start: Integer
    # End byte offset in the node's text content (exclusive).
    attr_reader end: Integer
    # Annotation type.
    attr_reader kind: AnnotationKind

    def initialize: (start: Integer, end: Integer, kind: AnnotationKind) -> void
  end

  class ExtractionResult
    # General extraction result used by the core extraction API.
    #
    # This is the main result type returned by all extraction functions.

    attr_accessor content: String?
    attr_accessor mime_type: String?
    attr_accessor metadata: Metadata?
    # Extraction strategy used to produce the returned text.
    #
    # Populated when the extractor can reliably distinguish native text extraction,
    # OCR-only extraction, or mixed native/OCR output.
    attr_accessor extraction_method: ExtractionMethod?
    attr_accessor tables: Array[Table]?
    attr_accessor detected_languages: Array[String]?
    # Text chunks when chunking is enabled.
    #
    # When chunking configuration is provided, the content is split into
    # overlapping chunks for efficient processing. Each chunk contains the text,
    # optional embeddings (if enabled), and metadata about its position.
    attr_accessor chunks: Array[Chunk]?
    # Extracted images from the document.
    #
    # When image extraction is enabled via `ImageExtractionConfig`, this field
    # contains all images found in the document with their raw data and metadata.
    # Each image may optionally contain a nested `ocr_result` if OCR was performed.
    attr_accessor images: Array[ExtractedImage]?
    # Per-page content when page extraction is enabled.
    #
    # When page extraction is configured, the document is split into per-page content
    # with tables and images mapped to their respective pages.
    attr_accessor pages: Array[PageContent]?
    # Semantic elements when element-based result format is enabled.
    #
    # When result_format is set to ElementBased, this field contains semantic
    # elements with type classification, unique identifiers, and metadata for
    # Unstructured-compatible element-based processing.
    attr_accessor elements: Array[Element]?
    # Rich Djot content structure (when extracting Djot documents).
    #
    # When extracting Djot documents with structured extraction enabled,
    # this field contains the full semantic structure including:
    # - Block-level elements with nesting
    # - Inline formatting with attributes
    # - Links, images, footnotes
    # - Math expressions
    # - Complete attribute information
    #
    # The `content` field still contains plain text for backward compatibility.
    #
    # Always `None` for non-Djot documents.
    attr_accessor djot_content: DjotContent?
    # OCR elements with full spatial and confidence metadata.
    #
    # When OCR is performed with element extraction enabled, this field contains
    # the structured representation of detected text including:
    # - Bounding geometry (rectangles or quadrilaterals)
    # - Confidence scores (detection and recognition)
    # - Rotation information
    # - Hierarchical relationships (Tesseract only)
    #
    # This field preserves all metadata that would otherwise be lost when
    # converting to plain text or markdown output formats.
    #
    # Only populated when `OcrElementConfig.include_elements` is true.
    attr_accessor ocr_elements: Array[OcrElement]?
    # Structured document tree (when document structure extraction is enabled).
    #
    # When `include_document_structure` is true in `ExtractionConfig`, this field
    # contains the full hierarchical representation of the document including:
    # - Heading-driven section nesting
    # - Table grids with cell-level metadata
    # - Content layer classification (body, header, footer, footnote)
    # - Inline text annotations (formatting, links)
    # - Bounding boxes and page numbers
    #
    # Independent of `result_format` — can be combined with Unified or ElementBased.
    attr_accessor document: DocumentStructure?
    # Extracted keywords when keyword extraction is enabled.
    #
    # When keyword extraction (RAKE or YAKE) is configured, this field contains
    # the extracted keywords with scores, algorithm info, and position data.
    # Previously stored in `metadata.additional["keywords"]`.
    attr_accessor extracted_keywords: Array[Keyword]?
    # Document quality score from quality analysis.
    #
    # A value between 0.0 and 1.0 indicating the overall text quality.
    # Previously stored in `metadata.additional["quality_score"]`.
    attr_accessor quality_score: Float?
    # Non-fatal warnings collected during processing pipeline stages.
    #
    # Captures errors from optional pipeline features (embedding, chunking,
    # language detection, output formatting) that don't prevent extraction
    # but may indicate degraded results.
    # Previously stored as individual keys in `metadata.additional`.
    attr_accessor processing_warnings: Array[ProcessingWarning]?
    # PDF annotations extracted from the document.
    #
    # When annotation extraction is enabled via `PdfConfig::extract_annotations`,
    # this field contains text notes, highlights, links, stamps, and other
    # annotations found in PDF documents.
    attr_accessor annotations: Array[PdfAnnotation]?
    # Nested extraction results from archive contents.
    #
    # When extracting archives, each processable file inside produces its own
    # full extraction result. Set to `None` for non-archive formats.
    # Use `max_archive_depth` in config to control recursion depth.
    attr_accessor children: Array[ArchiveEntry]?
    # URIs/links discovered during document extraction.
    #
    # Contains hyperlinks, image references, citations, email addresses, and
    # other URI-like references found in the document. Always extracted when
    # present in the source document.
    attr_accessor uris: Array[Uri]?
    # Structured extraction output from LLM-based JSON schema extraction.
    #
    # When `structured_extraction` is configured in `ExtractionConfig`, the
    # extracted document content is sent to a VLM with the provided JSON schema.
    # The response is parsed and stored here as a JSON value matching the schema.
    attr_accessor structured_output: untyped?
    # Code intelligence results from tree-sitter analysis.
    #
    # Populated when extracting source code files with the `tree-sitter` feature.
    # Contains metrics, structural analysis, imports/exports, comments,
    # docstrings, symbols, diagnostics, and optionally chunked code segments.
    attr_accessor code_intelligence: String?
    # LLM token usage and cost data for all LLM calls made during this extraction.
    #
    # Contains one entry per LLM call. Multiple entries are produced when
    # VLM OCR, structured extraction, and/or LLM embeddings all run during
    # the same extraction.
    #
    # `None` when no LLM was used.
    attr_accessor llm_usage: Array[LlmUsage]?
    # Pre-rendered content in the requested output format.
    #
    # Populated during `derive_extraction_result` before tree derivation consumes
    # element data. `apply_output_format` swaps this into `content` at the end
    # of the pipeline, after post-processors have operated on plain text.
    attr_accessor formatted_content: String?
    # Structured hOCR document for the OCR+layout pipeline.
    #
    # When tesseract produces hOCR output, the parsed `InternalDocument` carries
    # paragraph structure with bounding boxes and confidence scores. The layout
    # classification step enriches these elements before final rendering.
    attr_accessor ocr_internal_document: String?

    def initialize: (content: String, mime_type: String, metadata: Metadata, ?extraction_method: ExtractionMethod, tables: Array[Table], ?detected_languages: Array[String], ?chunks: Array[Chunk], ?images: Array[ExtractedImage], ?pages: Array[PageContent], ?elements: Array[Element], ?djot_content: DjotContent, ?ocr_elements: Array[OcrElement], ?document: DocumentStructure, ?extracted_keywords: Array[Keyword], ?quality_score: Float, processing_warnings: Array[ProcessingWarning], ?annotations: Array[PdfAnnotation], ?children: Array[ArchiveEntry], ?uris: Array[Uri], ?structured_output: untyped, ?code_intelligence: String, ?llm_usage: Array[LlmUsage], ?formatted_content: String, ?ocr_internal_document: String) -> void
    # Convert from an OCR result.
    def self.from_ocr: (OcrExtractionResult ocr) -> ExtractionResult
  end

  class ArchiveEntry
    # A single file extracted from an archive.
    #
    # When archives (ZIP, TAR, 7Z, GZIP) are extracted with recursive extraction
    # enabled, each processable file produces its own full `ExtractionResult`.

    # Archive-relative file path (e.g. "folder/document.pdf").
    attr_reader path: String
    # Detected MIME type of the file.
    attr_reader mime_type: String
    # Full extraction result for this file.
    attr_reader result: ExtractionResult

    def initialize: (path: String, mime_type: String, result: ExtractionResult) -> void
  end

  class ProcessingWarning
    # A non-fatal warning from a processing pipeline stage.
    #
    # Captures errors from optional features that don't prevent extraction
    # but may indicate degraded results.

    # The pipeline stage or feature that produced this warning
    # (e.g., "embedding", "chunking", "language_detection", "output_format").
    attr_reader source: String
    # Human-readable description of what went wrong.
    attr_reader message: String

    def initialize: (source: String, message: String) -> void
  end

  class LlmUsage
    # Token usage and cost data for a single LLM call made during extraction.
    #
    # Populated when VLM OCR, structured extraction, or LLM-based embeddings
    # are used. Multiple entries may be present when multiple LLM calls occur
    # within one extraction (e.g. VLM OCR + structured extraction).

    # The LLM model identifier (e.g. "openai/gpt-4o", "anthropic/claude-sonnet-4-20250514").
    attr_accessor model: String?
    # The pipeline stage that triggered this LLM call
    # (e.g. "vlm_ocr", "structured_extraction", "embeddings").
    attr_accessor source: String?
    # Number of input/prompt tokens consumed.
    attr_accessor input_tokens: Integer?
    # Number of output/completion tokens generated.
    attr_accessor output_tokens: Integer?
    # Total tokens (input + output).
    attr_accessor total_tokens: Integer?
    # Estimated cost in USD based on the provider's published pricing.
    attr_accessor estimated_cost: Float?
    # Why the model stopped generating (e.g. "stop", "length", "content_filter").
    attr_accessor finish_reason: String?

    def initialize: (model: String, source: String, ?input_tokens: Integer, ?output_tokens: Integer, ?total_tokens: Integer, ?estimated_cost: Float, ?finish_reason: String) -> void
  end

  class Chunk
    # A text chunk with optional embedding and metadata.
    #
    # Chunks are created when chunking is enabled in `ExtractionConfig`. Each chunk
    # contains the text content, optional embedding vector (if embedding generation
    # is configured), and metadata about its position in the document.

    # The text content of this chunk.
    attr_reader content: String
    # Semantic structural classification of this chunk.
    #
    # Assigned by the heuristic classifier based on content patterns and
    # heading context. Defaults to `ChunkType::Unknown` when no rule matches.
    attr_reader chunk_type: ChunkType
    # Optional embedding vector for this chunk.
    #
    # Only populated when `EmbeddingConfig` is provided in chunking configuration.
    # The dimensionality depends on the chosen embedding model.
    attr_reader embedding: Array[Float]
    # Metadata about this chunk's position and properties.
    attr_reader metadata: ChunkMetadata

    def initialize: (content: String, chunk_type: ChunkType, ?embedding: Array[Float], metadata: ChunkMetadata) -> void
  end

  class HeadingContext
    # Heading context for a chunk within a Markdown document.
    #
    # Contains the heading hierarchy from document root to this chunk's section.

    # The heading hierarchy from document root to this chunk's section.
    # Index 0 is the outermost (h1), last element is the most specific.
    attr_reader headings: Array[HeadingLevel]

    def initialize: (headings: Array[HeadingLevel]) -> void
  end

  class HeadingLevel
    # A single heading in the hierarchy.

    # Heading depth (1 = h1, 2 = h2, etc.)
    attr_reader level: Integer
    # The text content of the heading.
    attr_reader text: String

    def initialize: (level: Integer, text: String) -> void
  end

  class ChunkMetadata
    # Metadata about a chunk's position in the original document.

    # Byte offset where this chunk starts in the original text (UTF-8 valid boundary).
    attr_reader byte_start: Integer
    # Byte offset where this chunk ends in the original text (UTF-8 valid boundary).
    attr_reader byte_end: Integer
    # Number of tokens in this chunk (if available).
    #
    # This is calculated by the embedding model's tokenizer if embeddings are enabled.
    attr_reader token_count: Integer
    # Zero-based index of this chunk in the document.
    attr_reader chunk_index: Integer
    # Total number of chunks in the document.
    attr_reader total_chunks: Integer
    # First page number this chunk spans (1-indexed).
    #
    # Only populated when page tracking is enabled in extraction configuration.
    attr_reader first_page: Integer
    # Last page number this chunk spans (1-indexed, equal to first_page for single-page chunks).
    #
    # Only populated when page tracking is enabled in extraction configuration.
    attr_reader last_page: Integer
    # Heading context when using Markdown chunker.
    #
    # Contains the heading hierarchy this chunk falls under.
    # Only populated when `ChunkerType::Markdown` is used.
    attr_reader heading_context: HeadingContext
    # Indices into `ExtractionResult.images` for images on pages covered by this chunk.
    #
    # Contains zero-based indices into the top-level `images` collection for every
    # image whose `page_number` falls within `[first_page, last_page]`.
    # Empty when image extraction is disabled or the chunk spans no pages with images.
    attr_reader image_indices: Array[Integer]

    def initialize: (byte_start: Integer, byte_end: Integer, ?token_count: Integer, chunk_index: Integer, total_chunks: Integer, ?first_page: Integer, ?last_page: Integer, ?heading_context: HeadingContext, image_indices: Array[Integer]) -> void
  end

  class ExtractedImage
    # Extracted image from a document.
    #
    # Contains raw image data, metadata, and optional nested OCR results.
    # Raw bytes allow cross-language compatibility - users can convert to
    # PIL.Image (Python), Sharp (Node.js), or other formats as needed.

    # Raw image data (PNG, JPEG, WebP, etc. bytes).
    # Uses `bytes::Bytes` for cheap cloning of large buffers.
    attr_reader data: String
    # Image format (e.g., "jpeg", "png", "webp")
    # Uses Cow<'static, str> to avoid allocation for static literals.
    attr_reader format: String
    # Zero-indexed position of this image in the document/page
    attr_reader image_index: Integer
    # Page/slide number where image was found (1-indexed)
    attr_reader page_number: Integer
    # Image width in pixels
    attr_reader width: Integer
    # Image height in pixels
    attr_reader height: Integer
    # Colorspace information (e.g., "RGB", "CMYK", "Gray")
    attr_reader colorspace: String
    # Bits per color component (e.g., 8, 16)
    attr_reader bits_per_component: Integer
    # Whether this image is a mask image
    attr_reader is_mask: bool
    # Optional description of the image
    attr_reader description: String
    # Nested OCR extraction result (if image was OCRed)
    #
    # When OCR is performed on this image, the result is embedded here
    # rather than in a separate collection, making the relationship explicit.
    attr_reader ocr_result: ExtractionResult
    # Bounding box of the image on the page (PDF coordinates: x0=left, y0=bottom, x1=right, y1=top).
    # Only populated for PDF-extracted images when position data is available from the PDF extractor.
    attr_reader bounding_box: String
    # Original source path of the image within the document archive (e.g., "media/image1.png" in DOCX).
    # Used for rendering image references when the binary data is not extracted.
    attr_reader source_path: String
    # Heuristic classification of what this image likely depicts.
    # `None` if classification was disabled or inconclusive.
    attr_reader image_kind: ImageKind
    # Confidence score for `image_kind`, in the range 0.0 to 1.0.
    attr_reader kind_confidence: Float
    # Identifier shared across images that form a single logical figure
    # (e.g. all raster tiles of one technical drawing). `None` for singletons.
    attr_reader cluster_id: Integer

    def initialize: (data: String, format: String, image_index: Integer, ?page_number: Integer, ?width: Integer, ?height: Integer, ?colorspace: String, ?bits_per_component: Integer, is_mask: bool, ?description: String, ?ocr_result: ExtractionResult, ?bounding_box: String, ?source_path: String, ?image_kind: ImageKind, ?kind_confidence: Float, ?cluster_id: Integer) -> void
  end

  class ElementMetadata
    # Metadata for a semantic element.

    # Page number (1-indexed)
    attr_reader page_number: Integer
    # Source filename or document name
    attr_reader filename: String
    # Bounding box coordinates if available
    attr_reader coordinates: String
    # Position index in the element sequence
    attr_reader element_index: Integer
    # Additional custom metadata
    attr_reader additional: Hash[String, String]

    def initialize: (?page_number: Integer, ?filename: String, ?coordinates: String, ?element_index: Integer, additional: Hash[String, String]) -> void
  end

  class Element
    # Semantic element extracted from document.
    #
    # Represents a logical unit of content with semantic classification,
    # unique identifier, and metadata for tracking origin and position.

    # Unique element identifier
    attr_reader element_id: String
    # Semantic type of this element
    attr_reader element_type: ElementType
    # Text content of the element
    attr_reader text: String
    # Metadata about the element
    attr_reader metadata: ElementMetadata

    def initialize: (element_id: String, element_type: ElementType, text: String, metadata: ElementMetadata) -> void
  end

  class ExcelWorkbook
    # Excel workbook representation.
    #
    # Contains all sheets from an Excel file (.xlsx, .xls, etc.) with
    # extracted content and metadata.

    # All sheets in the workbook
    attr_reader sheets: Array[ExcelSheet]
    # Workbook-level metadata (author, creation date, etc.)
    attr_reader metadata: Hash[String, String]

    def initialize: (sheets: Array[ExcelSheet], metadata: Hash[String, String]) -> void
  end

  class ExcelSheet
    # Single Excel worksheet.
    #
    # Represents one sheet from an Excel workbook with its content
    # converted to Markdown format and dimensional statistics.

    # Sheet name as it appears in Excel
    attr_reader name: String
    # Sheet content converted to Markdown tables
    attr_reader markdown: String
    # Number of rows
    attr_reader row_count: Integer
    # Number of columns
    attr_reader col_count: Integer
    # Total number of non-empty cells
    attr_reader cell_count: Integer
    # Pre-extracted table cells (2D vector of cell values)
    # Populated during markdown generation to avoid re-parsing markdown.
    # None for empty sheets.
    attr_reader table_cells: Array[Array[String]]

    def initialize: (name: String, markdown: String, row_count: Integer, col_count: Integer, cell_count: Integer, ?table_cells: Array[Array[String]]) -> void
  end

  class XmlExtractionResult
    # XML extraction result.
    #
    # Contains extracted text content from XML files along with
    # structural statistics about the XML document.

    # Extracted text content (XML structure filtered out)
    attr_reader content: String
    # Total number of XML elements processed
    attr_reader element_count: Integer
    # List of unique element names found (sorted)
    attr_reader unique_elements: Array[String]

    def initialize: (content: String, element_count: Integer, unique_elements: Array[String]) -> void
  end

  class TextExtractionResult
    # Plain text and Markdown extraction result.
    #
    # Contains the extracted text along with statistics and,
    # for Markdown files, structural elements like headers and links.

    # Extracted text content
    attr_reader content: String
    # Number of lines
    attr_reader line_count: Integer
    # Number of words
    attr_reader word_count: Integer
    # Number of characters
    attr_reader character_count: Integer
    # Markdown headers (text only, Markdown files only)
    attr_reader headers: Array[String]
    # Markdown links as (text, URL) tuples (Markdown files only)
    attr_reader links: Array[String]
    # Code blocks as (language, code) tuples (Markdown files only)
    attr_reader code_blocks: Array[String]

    def initialize: (content: String, line_count: Integer, word_count: Integer, character_count: Integer, ?headers: Array[String], ?links: Array[String], ?code_blocks: Array[String]) -> void
  end

  class PptxExtractionResult
    # PowerPoint (PPTX) extraction result.
    #
    # Contains extracted slide content, metadata, and embedded images/tables.

    # Extracted text content from all slides
    attr_reader content: String
    # Presentation metadata
    attr_reader metadata: PptxMetadata
    # Total number of slides
    attr_reader slide_count: Integer
    # Total number of embedded images
    attr_reader image_count: Integer
    # Total number of tables
    attr_reader table_count: Integer
    # Extracted images from the presentation
    attr_reader images: Array[ExtractedImage]
    # Slide structure with boundaries (when page tracking is enabled)
    attr_reader page_structure: PageStructure
    # Per-slide content (when page tracking is enabled)
    attr_reader page_contents: Array[PageContent]
    # Structured document representation
    attr_reader document: DocumentStructure
    # Hyperlinks discovered in slides as (url, optional_label) pairs.
    attr_reader hyperlinks: Array[String]
    # Office metadata extracted from docProps/core.xml and docProps/app.xml.
    #
    # Contains keys like "title", "author", "created_by", "subject", "keywords",
    # "modified_by", "created_at", "modified_at", etc.
    attr_reader office_metadata: Hash[String, String]

    def initialize: (content: String, metadata: PptxMetadata, slide_count: Integer, image_count: Integer, table_count: Integer, images: Array[ExtractedImage], ?page_structure: PageStructure, ?page_contents: Array[PageContent], ?document: DocumentStructure, hyperlinks: Array[String], office_metadata: Hash[String, String]) -> void
  end

  class EmailExtractionResult
    # Email extraction result.
    #
    # Complete representation of an extracted email message (.eml or .msg)
    # including headers, body content, and attachments.

    # Email subject line
    attr_reader subject: String
    # Sender email address
    attr_reader from_email: String
    # Primary recipient email addresses
    attr_reader to_emails: Array[String]
    # CC recipient email addresses
    attr_reader cc_emails: Array[String]
    # BCC recipient email addresses
    attr_reader bcc_emails: Array[String]
    # Email date/timestamp
    attr_reader date: String
    # Message-ID header value
    attr_reader message_id: String
    # Plain text version of the email body
    attr_reader plain_text: String
    # HTML version of the email body
    attr_reader html_content: String
    # Cleaned/processed text content. Aliased as `cleaned_text` for back-compat.
    attr_reader content: String
    # List of email attachments
    attr_reader attachments: Array[EmailAttachment]
    # Additional email headers and metadata
    attr_reader metadata: Hash[String, String]

    def initialize: (?subject: String, ?from_email: String, to_emails: Array[String], cc_emails: Array[String], bcc_emails: Array[String], ?date: String, ?message_id: String, ?plain_text: String, ?html_content: String, content: String, attachments: Array[EmailAttachment], metadata: Hash[String, String]) -> void
  end

  class EmailAttachment
    # Email attachment representation.
    #
    # Contains metadata and optionally the content of an email attachment.

    # Attachment name (from Content-Disposition header)
    attr_reader name: String
    # Filename of the attachment
    attr_reader filename: String
    # MIME type of the attachment
    attr_reader mime_type: String
    # Size in bytes
    attr_reader size: Integer
    # Whether this attachment is an image
    attr_reader is_image: bool
    # Attachment data (if extracted).
    # Uses `bytes::Bytes` for cheap cloning of large buffers.
    attr_reader data: String

    def initialize: (?name: String, ?filename: String, ?mime_type: String, ?size: Integer, is_image: bool, ?data: String) -> void
  end

  class OcrExtractionResult
    # OCR extraction result.
    #
    # Result of performing OCR on an image or scanned document,
    # including recognized text and detected tables.

    # Recognized text content
    attr_reader content: String
    # Original MIME type of the processed image
    attr_reader mime_type: String
    # OCR processing metadata (confidence scores, language, etc.)
    attr_reader metadata: Hash[String, untyped]
    # Tables detected and extracted via OCR
    attr_reader tables: Array[OcrTable]
    # Structured OCR elements with bounding boxes and confidence scores.
    # Available when TSV output is requested or table detection is enabled.
    attr_reader ocr_elements: Array[OcrElement]
    # Structured document produced from hOCR parsing.
    # Carries paragraph structure, bounding boxes, and confidence scores
    # that the flattened `content` string discards.
    attr_reader internal_document: String

    def initialize: (content: String, mime_type: String, metadata: Hash[String, untyped], tables: Array[OcrTable], ?ocr_elements: Array[OcrElement], ?internal_document: String) -> void
  end

  class OcrTable
    # Table detected via OCR.
    #
    # Represents a table structure recognized during OCR processing.

    # Table cells as a 2D vector (rows × columns)
    attr_reader cells: Array[Array[String]]
    # Markdown representation of the table
    attr_reader markdown: String
    # Page number where the table was found (1-indexed)
    attr_reader page_number: Integer
    # Bounding box of the table in pixel coordinates (from OCR word positions).
    attr_reader bounding_box: OcrTableBoundingBox

    def initialize: (cells: Array[Array[String]], markdown: String, page_number: Integer, ?bounding_box: OcrTableBoundingBox) -> void
  end

  class OcrTableBoundingBox
    # Bounding box for an OCR-detected table in pixel coordinates.

    # Left x-coordinate (pixels)
    attr_reader left: Integer
    # Top y-coordinate (pixels)
    attr_reader top: Integer
    # Right x-coordinate (pixels)
    attr_reader right: Integer
    # Bottom y-coordinate (pixels)
    attr_reader bottom: Integer

    def initialize: (left: Integer, top: Integer, right: Integer, bottom: Integer) -> void
  end

  class ImagePreprocessingConfig
    # Image preprocessing configuration for OCR.
    #
    # These settings control how images are preprocessed before OCR to improve
    # text recognition quality. Different preprocessing strategies work better
    # for different document types.

    # Target DPI for the image (300 is standard, 600 for small text).
    attr_accessor target_dpi: Integer?
    # Auto-detect and correct image rotation.
    attr_accessor auto_rotate: bool?
    # Correct skew (tilted images).
    attr_accessor deskew: bool?
    # Remove noise from the image.
    attr_accessor denoise: bool?
    # Enhance contrast for better text visibility.
    attr_accessor contrast_enhance: bool?
    # Binarization method: "otsu", "sauvola", "adaptive".
    attr_accessor binarization_method: String?
    # Invert colors (white text on black → black on white).
    attr_accessor invert_colors: bool?

    def initialize: (target_dpi: Integer, auto_rotate: bool, deskew: bool, denoise: bool, contrast_enhance: bool, binarization_method: String, invert_colors: bool) -> void
    def self.default: () -> ImagePreprocessingConfig
  end

  class TesseractConfig
    # Tesseract OCR configuration.
    #
    # Provides fine-grained control over Tesseract OCR engine parameters.
    # Most users can use the defaults, but these settings allow optimization
    # for specific document types (invoices, handwriting, etc.).

    # Language code (e.g., "eng", "deu", "fra")
    attr_accessor language: String?
    # Page Segmentation Mode (0-13).
    #
    # Common values:
    # - 3: Fully automatic page segmentation (native default)
    # - 6: Assume a single uniform block of text (WASM default — avoids layout-analysis hang)
    # - 11: Sparse text with no particular order
    attr_accessor psm: Integer?
    # Output format ("text" or "markdown")
    attr_accessor output_format: String?
    # OCR Engine Mode (0-3).
    #
    # - 0: Legacy engine only
    # - 1: Neural nets (LSTM) only (usually best)
    # - 2: Legacy + LSTM
    # - 3: Default (based on what's available)
    attr_accessor oem: Integer?
    # Minimum confidence threshold (0.0-100.0).
    #
    # Words with confidence below this threshold may be rejected or flagged.
    attr_accessor min_confidence: Float?
    # Image preprocessing configuration.
    #
    # Controls how images are preprocessed before OCR. Can significantly
    # improve quality for scanned documents or low-quality images.
    attr_accessor preprocessing: ImagePreprocessingConfig?
    # Enable automatic table detection and reconstruction
    attr_accessor enable_table_detection: bool?
    # Minimum confidence threshold for table detection (0.0-1.0)
    attr_accessor table_min_confidence: Float?
    # Column threshold for table detection (pixels)
    attr_accessor table_column_threshold: Integer?
    # Row threshold ratio for table detection (0.0-1.0)
    attr_accessor table_row_threshold_ratio: Float?
    # Enable OCR result caching
    attr_accessor use_cache: bool?
    # Use pre-adapted templates for character classification
    attr_accessor classify_use_pre_adapted_templates: bool?
    # Enable N-gram language model
    attr_accessor language_model_ngram_on: bool?
    # Don't reject good words during block-level processing
    attr_accessor tessedit_dont_blkrej_good_wds: bool?
    # Don't reject good words during row-level processing
    attr_accessor tessedit_dont_rowrej_good_wds: bool?
    # Enable dictionary correction
    attr_accessor tessedit_enable_dict_correction: bool?
    # Whitelist of allowed characters (empty = all allowed)
    attr_accessor tessedit_char_whitelist: String?
    # Blacklist of forbidden characters (empty = none forbidden)
    attr_accessor tessedit_char_blacklist: String?
    # Use primary language params model
    attr_accessor tessedit_use_primary_params_model: bool?
    # Variable-width space detection
    attr_accessor textord_space_size_is_variable: bool?
    # Use adaptive thresholding method
    attr_accessor thresholding_method: bool?

    def initialize: (language: String, psm: Integer, output_format: String, oem: Integer, min_confidence: Float, ?preprocessing: ImagePreprocessingConfig, enable_table_detection: bool, table_min_confidence: Float, table_column_threshold: Integer, table_row_threshold_ratio: Float, use_cache: bool, classify_use_pre_adapted_templates: bool, language_model_ngram_on: bool, tessedit_dont_blkrej_good_wds: bool, tessedit_dont_rowrej_good_wds: bool, tessedit_enable_dict_correction: bool, tessedit_char_whitelist: String, tessedit_char_blacklist: String, tessedit_use_primary_params_model: bool, textord_space_size_is_variable: bool, thresholding_method: bool) -> void
    def self.default: () -> TesseractConfig
  end

  class ImagePreprocessingMetadata
    # Image preprocessing metadata.
    #
    # Tracks the transformations applied to an image during OCR preprocessing,
    # including DPI normalization, resizing, and resampling.

    # Original image dimensions (width, height) in pixels
    attr_reader original_dimensions: Array[Integer]
    # Original image DPI (horizontal, vertical)
    attr_reader original_dpi: Array[Float]
    # Target DPI from configuration
    attr_reader target_dpi: Integer
    # Scaling factor applied to the image
    attr_reader scale_factor: Float
    # Whether DPI was auto-adjusted based on content
    attr_reader auto_adjusted: bool
    # Final DPI after processing
    attr_reader final_dpi: Integer
    # New dimensions after resizing (if resized)
    attr_reader new_dimensions: Array[Integer]
    # Resampling algorithm used ("LANCZOS3", "CATMULLROM", etc.)
    attr_reader resample_method: String
    # Whether dimensions were clamped to max_image_dimension
    attr_reader dimension_clamped: bool
    # Calculated optimal DPI (if auto_adjust_dpi enabled)
    attr_reader calculated_dpi: Integer
    # Whether resize was skipped (dimensions already optimal)
    attr_reader skipped_resize: bool
    # Error message if resize failed
    attr_reader resize_error: String

    def initialize: (original_dimensions: Array[Integer], original_dpi: Array[Float], target_dpi: Integer, scale_factor: Float, auto_adjusted: bool, final_dpi: Integer, ?new_dimensions: Array[Integer], resample_method: String, dimension_clamped: bool, ?calculated_dpi: Integer, skipped_resize: bool, ?resize_error: String) -> void
  end

  class Metadata
    # Extraction result metadata.
    #
    # Contains common fields applicable to all formats, format-specific metadata
    # via a discriminated union, and additional custom fields from postprocessors.

    # Document title
    attr_accessor title: String?
    # Document subject or description
    attr_accessor subject: String?
    # Primary author(s) - always Vec for consistency
    attr_accessor authors: Array[String]?
    # Keywords/tags - always Vec for consistency
    attr_accessor keywords: Array[String]?
    # Primary language (ISO 639 code)
    attr_accessor language: String?
    # Creation timestamp (ISO 8601 format)
    attr_accessor created_at: String?
    # Last modification timestamp (ISO 8601 format)
    attr_accessor modified_at: String?
    # User who created the document
    attr_accessor created_by: String?
    # User who last modified the document
    attr_accessor modified_by: String?
    # Page/slide/sheet structure with boundaries
    attr_accessor pages: PageStructure?
    # Format-specific metadata (discriminated union)
    #
    # Contains detailed metadata specific to the document format.
    # Serialized as a nested `"format"` object with a `format_type` discriminator field.
    attr_accessor format: FormatMetadata?
    # Image preprocessing metadata (when OCR preprocessing was applied)
    attr_accessor image_preprocessing: ImagePreprocessingMetadata?
    # JSON schema (for structured data extraction)
    attr_accessor json_schema: untyped?
    # Error metadata (for batch operations)
    attr_accessor error: ErrorMetadata?
    # Extraction duration in milliseconds (for benchmarking).
    #
    # This field is populated by batch extraction to provide per-file timing
    # information. It's `None` for single-file extraction (which uses external timing).
    attr_accessor extraction_duration_ms: Integer?
    # Document category (from frontmatter or classification).
    attr_accessor category: String?
    # Document tags (from frontmatter).
    attr_accessor tags: Array[String]?
    # Document version string (from frontmatter).
    attr_accessor document_version: String?
    # Abstract or summary text (from frontmatter).
    attr_accessor abstract_text: String?
    # Output format identifier (e.g., "markdown", "html", "text").
    #
    # Set by the output format pipeline stage when format conversion is applied.
    # Previously stored in `metadata.additional["output_format"]`.
    attr_accessor output_format: String?
    # Whether OCR was used during extraction.
    #
    # Set to `true` whenever the extraction pipeline ran an OCR backend
    # (Tesseract, PaddleOCR, VLM, etc.) and used that output as the primary
    # or fallback text. `false` means native text extraction was used exclusively.
    attr_accessor ocr_used: bool?
    # Additional custom fields from postprocessors.
    #
    # Serialized as a nested `"additional"` object (not flattened at root level).
    # Uses `Cow<'static, str>` keys so static string keys avoid allocation.
    attr_accessor additional: Hash[String, untyped]?

    def initialize: (?title: String, ?subject: String, ?authors: Array[String], ?keywords: Array[String], ?language: String, ?created_at: String, ?modified_at: String, ?created_by: String, ?modified_by: String, ?pages: PageStructure, ?format: FormatMetadata, ?image_preprocessing: ImagePreprocessingMetadata, ?json_schema: untyped, ?error: ErrorMetadata, ?extraction_duration_ms: Integer, ?category: String, ?tags: Array[String], ?document_version: String, ?abstract_text: String, ?output_format: String, ocr_used: bool, additional: Hash[String, untyped]) -> void
    # Returns `true` when no metadata fields, format-specific metadata, or
    # additional postprocessor fields are populated.
    def is_empty: () -> bool
  end

  class ExcelMetadata
    # Excel/spreadsheet format metadata.
    #
    # Identifies the document as a spreadsheet source via the `FormatMetadata::Excel`
    # discriminant. Sheet count and sheet names are stored inside this struct.

    # Number of sheets in the workbook.
    attr_accessor sheet_count: Integer?
    # Names of all sheets in the workbook.
    attr_accessor sheet_names: Array[String]?

    def initialize: (?sheet_count: Integer, ?sheet_names: Array[String]) -> void
  end

  class EmailMetadata
    # Email metadata extracted from .eml and .msg files.
    #
